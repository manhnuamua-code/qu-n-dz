   ConfigurationSaving = { Enabled = true, FolderName = "QuanDzHub", FileName = "Config" },
   KeySystem = false 
})

-- TAB CHỨC NĂNG
local Tab = Window:CreateTab("Tính năng VIP", 4483362458)

-- 1. ESP (Hiện khung người chơi)
Tab:CreateButton({
   Name = "Bật ESP Player",
   Callback = function()
       -- Code ESP
       for _, v in pairs(game.Players:GetPlayers()) do
           if v ~= game.Players.LocalPlayer and v.Character then
               local Highlight = Instance.new("Highlight", v.Character)
               Highlight.FillColor = Color3.fromRGB(255, 255, 255)
           end
       end
   end,
})

-- 2. FLY (Bay tự do)
Tab:CreateToggle({
   Name = "Chế độ Bay (Fly)",
   CurrentValue = false,
   Callback = function(Value)
       _G.Fly = Value
       local lp = game.Players.LocalPlayer
       local mouse = lp:GetMouse()
       task.spawn(function()
           while _G.Fly do
               if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                   lp.Character.HumanoidRootPart.Velocity = Vector3.new(0, 1, 0) -- Giữ cao độ
               end
               task.wait()
           end
       end)
   end,
})

