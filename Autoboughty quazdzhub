NextBtn.Position = UDim2.new(0.05, 0, 0.65, 0)
NextBtn.Text = "NEXT TARGET (SKIP)"
NextBtn.BackgroundColor3 = Color3.fromRGB(50, 0, 50)
NextBtn.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", NextBtn)

-- ================= LOGIC BAY (FLY) =================
local Target = nil
local Blacklist = {}

HuntBtn.MouseButton1Click:Connect(function()
    getgenv().Setting.AutoHunt = not getgenv().Setting.AutoHunt
    HuntBtn.Text = getgenv().Setting.AutoHunt and "FLY HUNT: ON" or "FLY HUNT: OFF"
    HuntBtn.BackgroundColor3 = getgenv().Setting.AutoHunt and Color3.fromRGB(100, 0, 100) or Color3.fromRGB(30, 0, 30)
end)

NextBtn.MouseButton1Click:Connect(function()
    if Target then Blacklist[Target.Name] = tick(); Target = nil end
end)

-- Xuyên tường & Chống nước (Có lương tâm)
rs.Stepped:Connect(function()
    if lp.Character then
        for _, v in pairs(lp.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

spawn(function()
    while task.wait() do
        if getgenv().Setting.AutoHunt then
            pcall(function()
                if Target and Target.Character and Target.Character:FindFirstChild("HumanoidRootPart") and Target.Character.Humanoid.Health > 0 then
                    local myRoot = lp.Character.HumanoidRootPart
                    local targetRoot = Target.Character.HumanoidRootPart
                    local targetPos = targetRoot.CFrame * CFrame.new(0, 0, 3.5)
                    local dist = (myRoot.Position - targetPos.Position).Magnitude
                    
                    if dist > 3 then
                        -- Cơ chế bay lướt cực nhanh (giống RedZ)
                        myRoot.Velocity = (targetPos.Position - myRoot.Position).Unit * getgenv().Setting.FlySpeed
                    else
                        -- Dính sát thì đứng im để Hoàng vả tay
                        myRoot.Velocity = Vector3.new(0, 0, 0)
                        myRoot.CFrame = targetPos
                    end
                else
                    Target = nil
                    for _, v in pairs(game.Players:GetPlayers()) do
                        if v ~= lp and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 and not v.Character:FindFirstChild("ForceField") and not Blacklist[v.Name] then
                            Target = v
                            break
                        end
                    end
                end
            end)
        end
    end
end)
