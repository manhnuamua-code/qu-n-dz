if not game:IsLoaded() then game.Loaded:Wait() end

getgenv().Setting = {
    ["AutoHunt"] = false,
    ["FlySpeed"] = 350, -- Tốc độ bay giống RedZ
}

local lp = game.Players.LocalPlayer
local rs = game:GetService("RunService")

-- ================= GUI WIBU EDITION =================
